---
/* Takasago 物件詳細 — B7: takasagoData の実コンテンツで再構成 */
import SiteLayout from "../../../layouts/SiteLayout.astro";
import PropertyDetail from "../../../components/PropertyDetail.astro";
import { LOCALES, localeParam, type Locale } from "../../../i18n/config";
import { getPageMeta, breadcrumbJsonLd, BASE_URL } from "../../../lib/seo";
import { translations } from "../../../i18n/translations";
import { localizedPath } from "../../../i18n/config";
import { takasagoData } from "../../../data/takasagoData";

export function getStaticPaths() {
  return LOCALES.map((locale) => ({
    params: { locale: localeParam(locale) },
    props: { lang: locale as Locale },
  }));
}

const { lang } = Astro.props as { lang: Locale };
const meta = getPageMeta("takasago", lang);
const breadcrumb = breadcrumbJsonLd([
  { name: translations[lang].nav.home, url: `${BASE_URL}${localizedPath(lang, "/")}` },
  { name: "yah.homes Takasago", url: `${BASE_URL}${localizedPath(lang, "/booking/takasago")}` },
]);
---

<SiteLayout lang={lang} path="/booking/takasago" title={meta.title} description={meta.description} jsonLd={[meta.jsonLd, breadcrumb].filter(Boolean)}>
  <PropertyDetail
    lang={lang}
    propertyKey="takasago"
    data={takasagoData[lang]}
    heroImage="/manus-storage/takasago-gallery-009_f3ff9cef.webp"
  />
</SiteLayout>
