---
/* Takasago 物件詳細 — B7: takasagoData の実コンテンツで再構成 */
import SiteLayout from "../../../layouts/SiteLayout.astro";
import PropertyDetail from "../../../components/PropertyDetail.astro";
import { LOCALES, localeParam, type Locale } from "../../../i18n/config";
import { getPageMeta } from "../../../lib/seo";
import { takasagoData } from "../../../data/takasagoData";

export function getStaticPaths() {
  return LOCALES.map((locale) => ({
    params: { locale: localeParam(locale) },
    props: { lang: locale as Locale },
  }));
}

const { lang } = Astro.props as { lang: Locale };
const meta = getPageMeta("takasago", lang);
---

<SiteLayout lang={lang} path="/booking/takasago" title={meta.title} description={meta.description} jsonLd={meta.jsonLd}>
  <PropertyDetail
    lang={lang}
    propertyKey="takasago"
    data={takasagoData[lang]}
    heroImage="/manus-storage/takasago-gallery-009_f3ff9cef.webp"
  />
</SiteLayout>
