---
import SiteLayout from "../../../layouts/SiteLayout.astro";
import { LOCALES, localeParam, localizedPath, type Locale } from "../../../i18n/config";
import { translations } from "../../../i18n/translations";
import { getPageMeta } from "../../../lib/seo";
import { PROPERTIES } from "../../../data/properties";

export function getStaticPaths() {
  return LOCALES.map((locale) => ({
    params: { locale: localeParam(locale) },
    props: { lang: locale as Locale },
  }));
}

const { lang } = Astro.props as { lang: Locale };
const t = translations[lang];
const meta = getPageMeta("booking", lang);

const cards = [
  { p: PROPERTIES.kiyokawa, name: t.properties.kiyokawa.name, info: t.properties.kiyokawa.info, detail: localizedPath(lang, "/booking/kiyokawa") },
  { p: PROPERTIES.takasago, name: t.properties.takasago.name, info: t.properties.takasago.info, detail: localizedPath(lang, "/booking/takasago") },
];
---

<SiteLayout lang={lang} path="/booking" title={meta.title} description={meta.description} jsonLd={meta.jsonLd}>
  <section class="section container">
    <p class="eyebrow">{t.properties.sectionLabel}</p>
    <h1 class="section-title">{t.bookingCta.heading}</h1>
    <div class="cards properties-grid">
      {
        cards.map((c) => (
          <article class="card">
            <a href={c.detail} class="card-img img-zoom"><img src={c.p.exterior} alt={c.name} loading="lazy" /></a>
            <div class="card-body">
              <h2>{c.name}</h2>
              <p class="card-meta">{c.p.bedrooms} {t.properties.bedrooms} · {c.p.capacity} {t.properties.people} · ★ {c.p.rating} ({c.p.reviewCount})</p>
              <p class="card-info">{c.info}</p>
              <div class="card-actions">
                <a class="btn-booking" href={c.detail}>{t.properties.bookingBtn}</a>
                <a class="btn-booking" href={c.p.airbnbUrl} target="_blank" rel="noopener">{t.properties.airbnbBtn}</a>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </section>
</SiteLayout>

<style>
  .section { padding: 4.5rem 1.5rem; }
  .eyebrow { font-size: 0.7rem; letter-spacing: 0.25em; text-transform: uppercase; color: var(--muted-foreground); margin-bottom: 0.75rem; }
  .section-title { font-size: clamp(1.5rem, 3.5vw, 2.25rem); font-weight: 500; margin-bottom: 1.5rem; }
  .cards { display: grid; gap: 2rem; margin-top: 1rem; }
  .card { border: 1px solid var(--border); background: #fff; display: flex; flex-direction: column; }
  .card-img { display: block; aspect-ratio: 4/3; overflow: hidden; }
  .card-img img { width: 100%; height: 100%; object-fit: cover; }
  .card-body { padding: 1.25rem 1.25rem 1.5rem; display: flex; flex-direction: column; gap: 0.5rem; }
  .card-body h2 { font-size: 1.25rem; font-weight: 500; }
  .card-meta { font-size: 0.8rem; color: var(--muted-foreground); }
  .card-info { font-size: 0.9rem; color: #444; margin-bottom: 0.5rem; }
  .card-actions { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-top: auto; }
</style>
