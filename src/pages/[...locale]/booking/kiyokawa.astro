---
/* Kiyokawa 物件詳細 — B7: kiyokawaData の実コンテンツで再構成 */
import SiteLayout from "../../../layouts/SiteLayout.astro";
import PropertyDetail from "../../../components/PropertyDetail.astro";
import { LOCALES, localeParam, type Locale } from "../../../i18n/config";
import { getPageMeta, breadcrumbJsonLd, BASE_URL } from "../../../lib/seo";
import { translations } from "../../../i18n/translations";
import { localizedPath } from "../../../i18n/config";
import { kiyokawaData } from "../../../data/kiyokawaData";

export function getStaticPaths() {
  return LOCALES.map((locale) => ({
    params: { locale: localeParam(locale) },
    props: { lang: locale as Locale },
  }));
}

const { lang } = Astro.props as { lang: Locale };
const meta = getPageMeta("kiyokawa", lang);
const breadcrumb = breadcrumbJsonLd([
  { name: translations[lang].nav.home, url: `${BASE_URL}${localizedPath(lang, "/")}` },
  { name: "yah.homes Kiyokawa", url: `${BASE_URL}${localizedPath(lang, "/booking/kiyokawa")}` },
]);
---

<SiteLayout lang={lang} path="/booking/kiyokawa" title={meta.title} description={meta.description} jsonLd={[meta.jsonLd, breadcrumb].filter(Boolean)}>
  <PropertyDetail
    lang={lang}
    propertyKey="kiyokawa"
    data={kiyokawaData[lang]}
    heroImage="/manus-storage/kiyokawa-gallery-009_95d58f6b.webp"
    floorPlanImage="/manus-storage/floorplan_kiyokawa_cba0e55d.webp"
  />
</SiteLayout>
