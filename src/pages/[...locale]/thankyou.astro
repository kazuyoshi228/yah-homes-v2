---
/* /thankyou — 旧サイトでは /booking と同一のコンバージョンページ。noindex（薄いページのため） */
import SiteLayout from "../../layouts/SiteLayout.astro";
import BookingConversion from "../../components/BookingConversion.astro";
import { LOCALES, localeParam, type Locale } from "../../i18n/config";
import { getPageMeta } from "../../lib/seo";

export function getStaticPaths() {
  return LOCALES.map((locale) => ({
    params: { locale: localeParam(locale) },
    props: { lang: locale as Locale },
  }));
}

const { lang } = Astro.props as { lang: Locale };
const meta = getPageMeta("thankyou", lang);
---

<SiteLayout lang={lang} path="/thankyou" title={meta.title} description={meta.description} noindex={true}>
  <BookingConversion lang={lang} />
</SiteLayout>
