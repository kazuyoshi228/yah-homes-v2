---
/* Home — 旧 Home.tsx のセクション構成を忠実に再現
   Hero → Properties（内包: Features / Access / OurReview / ComparisonTable）
   → Story → LocalsCTA → FAQ → Contact → BookingCTA */
import SiteLayout from "../../layouts/SiteLayout.astro";
import { LOCALES, localeParam, type Locale } from "../../i18n/config";
import { getPageMeta } from "../../lib/seo";
import InlineBookingCta from "../../components/home/InlineBookingCta.astro";
import HeroSection from "../../components/home/HeroSection.astro";
import PropertiesSection from "../../components/home/PropertiesSection.astro";
import FeaturesSection from "../../components/home/FeaturesSection.astro";
import AccessSection from "../../components/home/AccessSection.astro";
import OurReviewSection from "../../components/home/OurReviewSection.astro";
import ComparisonTable from "../../components/home/ComparisonTable.astro";
import StorySection from "../../components/home/StorySection.astro";
import LocalsCTASection from "../../components/home/LocalsCTASection.astro";
import FAQSection from "../../components/home/FAQSection.astro";
import PressSection from "../../components/PressSection.astro";
import ContactSection from "../../components/home/ContactSection.astro";
import BookingCTASection from "../../components/home/BookingCTASection.astro";

export function getStaticPaths() {
  return LOCALES.map((locale) => ({
    params: { locale: localeParam(locale) },
    props: { lang: locale as Locale },
  }));
}

const { lang } = Astro.props as { lang: Locale };
const meta = getPageMeta("home", lang);
---

<SiteLayout lang={lang} path="/" title={meta.title} description={meta.description} jsonLd={meta.jsonLd}>
  <HeroSection lang={lang} />
  <PropertiesSection lang={lang} />
  <FeaturesSection lang={lang} />
  <AccessSection lang={lang} />
  <OurReviewSection lang={lang} />
  <section class="home-cta-band"><InlineBookingCta lang={lang} ctaLocation="after_review" /></section>
  <ComparisonTable lang={lang} />
  <section class="home-cta-band"><InlineBookingCta lang={lang} ctaLocation="after_compare" /></section>
  <StorySection />
  <LocalsCTASection lang={lang} />
  <FAQSection lang={lang} />
  <PressSection />
  <ContactSection lang={lang} />
  <BookingCTASection lang={lang} />
</SiteLayout>

<style>
  /* セクション区切りの予約CTA帯（レビュー直後・比較表直後）。読み物を割らない控えめな余白 */
  .home-cta-band {
    background: #ffffff;
    padding: 2.5rem 1.5rem;
    display: flex;
    justify-content: center;
  }
</style>
