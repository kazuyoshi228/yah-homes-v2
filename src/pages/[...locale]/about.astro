---
import SiteLayout from "../../layouts/SiteLayout.astro";
import { LOCALES, localeParam, type Locale } from "../../i18n/config";
import { translations } from "../../i18n/translations";
import { getPageMeta } from "../../lib/seo";
import { DIRECTOR_IMAGE, STORY_IMAGE } from "../../data/properties";

export function getStaticPaths() {
  return LOCALES.map((locale) => ({
    params: { locale: localeParam(locale) },
    props: { lang: locale as Locale },
  }));
}

const { lang } = Astro.props as { lang: Locale };
const t = translations[lang];
const meta = getPageMeta("about", lang);
const d = t.director;

const blocks = [
  { heading: d.section2Heading, body: d.section2Body },
  { heading: d.section3Heading, body: d.section3Body },
  { heading: d.section4Heading, body: d.section4Body },
];
---

<SiteLayout lang={lang} path="/about" title={meta.title} description={meta.description} jsonLd={meta.jsonLd}>
  <section class="page-hero">
    <img src={STORY_IMAGE} alt="yah.homes" loading="eager" />
    <div class="page-hero-text container">
      <p class="eyebrow light">{t.story.sectionLabel}</p>
      <h1>{t.story.heading}</h1>
    </div>
  </section>

  <section class="section container narrow">
    {t.story.body.map((p) => <p class="body-copy">{p}</p>)}
  </section>

  <section class="section-alt">
    <div class="container split">
      <div class="split-img"><img src={DIRECTOR_IMAGE} alt={d.directorName} loading="lazy" /></div>
      <div>
        <p class="eyebrow">{d.sectionHeading}</p>
        <h2 class="section-title">{d.directorName}</h2>
        <p class="director-title">{d.directorTitle}</p>
        {d.intro.map((p) => <p class="body-copy">{p}</p>)}
      </div>
    </div>
  </section>

  <section class="section container narrow">
    {
      blocks.map((b) => (
        <div class="text-block">
          <h2 class="section-title sm">{b.heading}</h2>
          {b.body.map((p) => <p class="body-copy">{p}</p>)}
        </div>
      ))
    }
  </section>
</SiteLayout>

<style>
  .page-hero { position: relative; height: 46vh; min-height: 320px; overflow: hidden; }
  .page-hero img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .page-hero-text {
    position: absolute; inset: 0; display: flex; flex-direction: column; justify-content: flex-end;
    padding-bottom: 2.5rem; color: #fff;
    background: linear-gradient(to top, rgba(0,0,0,0.5), transparent 60%);
  }
  .page-hero-text h1 { font-size: clamp(2rem, 5vw, 3rem); font-weight: 500; }
  .eyebrow { font-size: 0.7rem; letter-spacing: 0.25em; text-transform: uppercase; color: var(--muted-foreground); margin-bottom: 0.75rem; }
  .eyebrow.light { color: rgba(255,255,255,0.85); }
  .section { padding: 4rem 1.5rem; }
  .section-alt { background: var(--secondary); padding: 4rem 0; }
  .narrow { max-width: 720px; }
  .section-title { font-size: clamp(1.5rem, 3.5vw, 2.25rem); font-weight: 500; line-height: 1.25; margin-bottom: 1.25rem; text-wrap: balance; }
  .section-title.sm { font-size: 1.35rem; margin-top: 2rem; }
  .body-copy { color: #333; margin-bottom: 1rem; }
  .director-title { font-size: 0.8rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted-foreground); margin-bottom: 1rem; }
  .split { display: grid; gap: 2.5rem; align-items: center; }
  .split-img { aspect-ratio: 4/3; overflow: hidden; }
  .split-img img { width: 100%; height: 100%; object-fit: cover; }
  @media (min-width: 768px) { .split { grid-template-columns: 1fr 1fr; } }
</style>
