---
/* About — 旧 About.tsx の忠実移植
   フルビューポートヒーロー(017) → ストーリーコピー → DirectorSection
   → Back to Home → BookingCTA */
import SiteLayout from "../../layouts/SiteLayout.astro";
import DirectorSection from "../../components/DirectorSection.astro";
import BookingCTASection from "../../components/home/BookingCTASection.astro";
import { LOCALES, localeParam, localizedPath, type Locale } from "../../i18n/config";
import { translations } from "../../i18n/translations";
import { getPageMeta, breadcrumbJsonLd, BASE_URL } from "../../lib/seo";
import { lucide } from "../../lib/lucide";
import { uiStrings } from "../../i18n/uiStrings";

export function getStaticPaths() {
  return LOCALES.map((locale) => ({
    params: { locale: localeParam(locale) },
    props: { lang: locale as Locale },
  }));
}

const { lang } = Astro.props as { lang: Locale };
const t = translations[lang];
const meta = getPageMeta("about", lang);
const ui = uiStrings[lang];

const ABOUT_HERO = "/manus-storage/017_10f920ac.webp";
const ABOUT_HERO_768 = "/manus-storage/017-768_776a4b9b.webp";
const ABOUT_HERO_480 = "/manus-storage/017-480_ef8bf0ed.webp";
const homeHref = localizedPath(lang, "/");

// パンくず（Home > About）
const aboutBreadcrumb = breadcrumbJsonLd([
  { name: t.nav.home, url: `${BASE_URL}${localizedPath(lang, "/")}` },
  { name: meta.title.split("|")[0].trim(), url: `${BASE_URL}${localizedPath(lang, "/about")}` },
]);

// 会社概要（登記情報・ユーザー確認済み 2026-07-16）。値は共通、ラベルのみ各言語。
const COMPANY_HEADING: Record<Locale, string> = {
  ja: "会社概要", en: "Company Information", ko: "회사 정보", zh: "公司資訊", th: "ข้อมูลบริษัท",
};
const L = (ja: string, en: string, ko: string, zh: string, th: string): Record<Locale, string> => ({ ja, en, ko, zh, th });
const COMPANY_ROWS: { label: Record<Locale, string>; value: string }[] = [
  { label: L("運営会社", "Company", "운영 회사", "營運公司", "บริษัท"), value: "ボンファイア株式会社（Bonfire Inc.）" },
  { label: L("代表取締役", "Representative Director", "대표이사", "代表董事", "กรรมการผู้จัดการ"), value: "山田一慶（Kazuyoshi Yamada）" },
  { label: L("所在地", "Address", "주소", "地址", "ที่อยู่"), value: "〒810-0011 福岡県福岡市中央区高砂1-18-7" },
  { label: L("創業", "Founded", "설립", "創業", "ก่อตั้ง"), value: "2018年1月5日" },
  { label: L("法人番号", "Corporate Number", "법인 번호", "法人編號", "เลขทะเบียนบริษัท"), value: "4010901041393" },
  { label: L("事業内容", "Business", "사업 내용", "營業項目", "ธุรกิจ"), value: "不動産売買・不動産開発・システム開発・貿易業" },
];
---

<SiteLayout lang={lang} path="/about" title={meta.title} description={meta.description} jsonLd={[meta.jsonLd, aboutBreadcrumb].filter(Boolean)}>
  <!-- HERO — フルビューポート（旧と同スタイル） -->
  <section class="about-hero">
    <img
      src={ABOUT_HERO}
      srcset={`${ABOUT_HERO_480} 480w, ${ABOUT_HERO_768} 768w, ${ABOUT_HERO} 1920w`}
      sizes="(max-width: 480px) 480px, (max-width: 768px) 768px, 1920px"
      alt=""
      aria-hidden="true"
      fetchpriority="high"
      decoding="async"
      width="1920"
      height="1455"
      class="about-hero-bg"
    />
    <div class="about-hero-grad" aria-hidden="true"></div>
    <div class="about-hero-text">
      <p class="hero-label">{t.aboutYahHomes}</p>
      <h1 class="hero-heading">{t.story.heading}</h1>
    </div>
  </section>

  <!-- About copy -->
  <div style="max-width:900px;margin:0 auto;padding:4rem 1.5rem 1rem;">
    <div class="reveal">
      {t.story.body.map((text) => <p class="story-p">{text}</p>)}
    </div>
  </div>

  <DirectorSection lang={lang} />

  <!-- 会社概要（NAP・E-E-A-T・登記情報。全言語共通の値＋ラベルのみ翻訳） -->
  <section class="company-info" id="company">
    <div class="company-inner">
      <h2 class="company-title">{COMPANY_HEADING[lang]}</h2>
      <dl class="company-dl">
        {COMPANY_ROWS.map((row) => (
          <div class="company-row">
            <dt>{row.label[lang]}</dt>
            <dd>{row.value}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <!-- Back to Home -->
  <section style="padding:4rem 1.5rem;text-align:center;background:#ffffff;">
    <a href={homeHref} class="back-btn">
      <Fragment set:html={lucide("chevronLeft", { size: 14, strokeWidth: 2.5 })} />
      {ui.backToHome}
    </a>
  </section>

  <BookingCTASection lang={lang} />
</SiteLayout>

<style>
  .company-info {
    background: #ffffff;
    padding: 4rem 1.5rem 2rem;
  }
  .company-inner {
    max-width: 640px;
    margin: 0 auto;
  }
  .company-title {
    font-size: clamp(1.15rem, 2.6vw, 1.5rem);
    font-weight: 500;
    color: #111111;
    margin-bottom: 1.75rem;
    padding-bottom: 0.6rem;
    border-bottom: 1px solid #eeeeee;
  }
  .company-dl {
    margin: 0;
  }
  .company-row {
    display: grid;
    grid-template-columns: 8rem 1fr;
    gap: 1rem;
    padding: 0.9rem 0;
    border-bottom: 1px solid #f2f2f2;
  }
  .company-row dt {
    font-size: 0.8rem;
    font-weight: 500;
    color: #999999;
  }
  .company-row dd {
    margin: 0;
    font-size: 0.875rem;
    line-height: 1.7;
    color: #222222;
  }
  @media (max-width: 520px) {
    .company-row {
      grid-template-columns: 1fr;
      gap: 0.2rem;
    }
  }
  .about-hero {
    position: relative;
    width: 100%;
    min-height: 100svh;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }
  .about-hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
    z-index: 0;
  }
  .about-hero-grad {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0) 0%,
      rgba(0, 0, 0, 0) 35%,
      rgba(0, 0, 0, 0.55) 75%,
      rgba(0, 0, 0, 0.72) 100%
    );
    z-index: 1;
  }
  .about-hero-text {
    position: relative;
    z-index: 2;
    max-width: 900px;
    width: 100%;
    margin: 0 auto;
    padding: 0 1.5rem 4rem;
  }
  .hero-label {
    font-size: clamp(0.65rem, 1.4vw, 0.8rem);
    font-weight: 500;
    color: rgba(255, 255, 255, 0.7);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }
  .hero-heading {
    font-size: clamp(2rem, 6vw, 4rem);
    font-weight: 500;
    color: #ffffff;
    line-height: 1.2;
    letter-spacing: -0.01em;
    text-shadow: 0 2px 16px rgba(0, 0, 0, 0.35);
    white-space: pre-line;
  }
  .story-p {
    font-size: clamp(1.05rem, 1.9vw, 1.2rem);
    font-weight: 300;
    color: #444444;
    line-height: 1.9;
    margin-bottom: 1.25rem;
  }
  .story-p:last-child {
    margin-bottom: 0;
  }
  .back-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.95rem;
    font-weight: 500;
    color: #111111;
    background: transparent;
    border: 1.5px solid #111111;
    letter-spacing: 0.02em;
    padding: 0.75rem 2rem;
    border-radius: 4px;
    text-decoration: none;
    transition: background 0.18s cubic-bezier(0.23, 1, 0.32, 1), color 0.18s cubic-bezier(0.23, 1, 0.32, 1),
      transform 0.16s cubic-bezier(0.23, 1, 0.32, 1);
  }
  .back-btn:hover {
    background: #111111;
    color: #ffffff;
  }
  .back-btn:active {
    transform: scale(0.97);
  }
</style>
