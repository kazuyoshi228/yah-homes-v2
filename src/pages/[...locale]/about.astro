---
/* About — 旧 About.tsx の忠実移植
   フルビューポートヒーロー(017) → ストーリーコピー → DirectorSection
   → Back to Home → BookingCTA */
import SiteLayout from "../../layouts/SiteLayout.astro";
import DirectorSection from "../../components/DirectorSection.astro";
import BookingCTASection from "../../components/home/BookingCTASection.astro";
import { LOCALES, localeParam, localizedPath, type Locale } from "../../i18n/config";
import { translations } from "../../i18n/translations";
import { getPageMeta } from "../../lib/seo";
import { lucide } from "../../lib/lucide";

export function getStaticPaths() {
  return LOCALES.map((locale) => ({
    params: { locale: localeParam(locale) },
    props: { lang: locale as Locale },
  }));
}

const { lang } = Astro.props as { lang: Locale };
const t = translations[lang];
const meta = getPageMeta("about", lang);

const ABOUT_HERO = "/manus-storage/017_10f920ac.webp";
const ABOUT_HERO_768 = "/manus-storage/017-768_776a4b9b.webp";
const ABOUT_HERO_480 = "/manus-storage/017-480_ef8bf0ed.webp";
const homeHref = localizedPath(lang, "/");
---

<SiteLayout lang={lang} path="/about" title={meta.title} description={meta.description} jsonLd={meta.jsonLd}>
  <!-- HERO — フルビューポート（旧と同スタイル） -->
  <section class="about-hero">
    <img
      src={ABOUT_HERO}
      srcset={`${ABOUT_HERO_480} 480w, ${ABOUT_HERO_768} 768w, ${ABOUT_HERO} 1920w`}
      sizes="(max-width: 480px) 480px, (max-width: 768px) 768px, 1920px"
      alt=""
      aria-hidden="true"
      fetchpriority="high"
      decoding="async"
      width="1920"
      height="1455"
      class="about-hero-bg"
    />
    <div class="about-hero-grad" aria-hidden="true"></div>
    <div class="about-hero-text">
      <p class="hero-label">{t.aboutYahHomes}</p>
      <h1 class="hero-heading">{t.story.heading}</h1>
    </div>
  </section>

  <!-- About copy -->
  <div style="max-width:900px;margin:0 auto;padding:4rem 1.5rem 3rem;">
    <div class="reveal">
      {t.story.body.map((text) => <p class="story-p">{text}</p>)}
    </div>
  </div>

  <DirectorSection lang={lang} />

  <!-- Back to Home -->
  <section style="padding:4rem 1.5rem;text-align:center;background:#ffffff;">
    <a href={homeHref} class="back-btn">
      <Fragment set:html={lucide("chevronLeft", { size: 14, strokeWidth: 2.5 })} />
      Back to Home
    </a>
  </section>

  <BookingCTASection lang={lang} />
</SiteLayout>

<style>
  .about-hero {
    position: relative;
    width: 100%;
    min-height: 100svh;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }
  .about-hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
    z-index: 0;
  }
  .about-hero-grad {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0) 0%,
      rgba(0, 0, 0, 0) 35%,
      rgba(0, 0, 0, 0.55) 75%,
      rgba(0, 0, 0, 0.72) 100%
    );
    z-index: 1;
  }
  .about-hero-text {
    position: relative;
    z-index: 2;
    max-width: 900px;
    width: 100%;
    margin: 0 auto;
    padding: 0 1.5rem 4rem;
  }
  .hero-label {
    font-size: clamp(0.65rem, 1.4vw, 0.8rem);
    font-weight: 500;
    color: rgba(255, 255, 255, 0.7);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }
  .hero-heading {
    font-size: clamp(2rem, 6vw, 4rem);
    font-weight: 500;
    color: #ffffff;
    line-height: 1.2;
    letter-spacing: -0.01em;
    text-shadow: 0 2px 16px rgba(0, 0, 0, 0.35);
    white-space: pre-line;
  }
  .story-p {
    font-size: 1rem;
    font-weight: 300;
    color: #444444;
    line-height: 1.9;
    margin-bottom: 1.25rem;
  }
  .story-p:last-child {
    margin-bottom: 0;
  }
  .back-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.95rem;
    font-weight: 500;
    color: #111111;
    background: transparent;
    border: 1.5px solid #111111;
    letter-spacing: 0.02em;
    padding: 0.75rem 2rem;
    border-radius: 4px;
    text-decoration: none;
    transition: background 0.18s cubic-bezier(0.23, 1, 0.32, 1), color 0.18s cubic-bezier(0.23, 1, 0.32, 1),
      transform 0.16s cubic-bezier(0.23, 1, 0.32, 1);
  }
  .back-btn:hover {
    background: #111111;
    color: #ffffff;
  }
  .back-btn:active {
    transform: scale(0.97);
  }
</style>
