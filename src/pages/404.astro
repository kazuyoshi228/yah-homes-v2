---
// 404 — ブランド化（ナビ・フッター・ホーム導線付き）。noindex。
import SiteLayout from "../layouts/SiteLayout.astro";
---

<SiteLayout
  lang="en"
  path="/"
  title="Page Not Found | yah.homes"
  description="The page you are looking for could not be found."
  noindex={true}
>
  <section class="nf">
    <p class="nf-code">404</p>
    <h1 class="nf-title">Page Not Found</h1>
    <p class="nf-body">The page you are looking for doesn't exist or has been moved.</p>
    <a href="/" class="nf-btn">Back to Home</a>
  </section>
</SiteLayout>

<style>
  .nf {
    min-height: 70svh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 8rem 1.5rem 4rem;
  }
  .nf-code {
    font-size: 0.8rem;
    letter-spacing: 0.25em;
    color: #aaaaaa;
    margin-bottom: 1rem;
  }
  .nf-title {
    font-size: clamp(1.75rem, 5vw, 3rem);
    font-weight: 500;
    color: #111111;
    letter-spacing: -0.01em;
    margin-bottom: 1rem;
  }
  .nf-body {
    font-size: 0.95rem;
    font-weight: 300;
    color: #666666;
    margin-bottom: 2.5rem;
  }
  .nf-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.95rem;
    font-weight: 500;
    color: #111111;
    border: 1.5px solid #111111;
    padding: 0.75rem 2rem;
    border-radius: 4px;
    text-decoration: none;
    transition: background 0.18s, color 0.18s;
  }
  .nf-btn:hover {
    background: #111111;
    color: #ffffff;
  }
</style>
