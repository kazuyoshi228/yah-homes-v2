---
// BaseLayout — 全ページ共通の <head>。SEO の核。
// title / description / canonical / hreflang / OGP / JSON-LD をビルド時に焼き込み、
// 全UAへ同一HTMLを配信する（旧サイトのUA出し分け・全ページ同一タイトルを廃止）。
import "../styles/global.css";
import {
  LOCALES,
  HREFLANG,
  DEFAULT_LOCALE,
  localizedPath,
  type Locale,
} from "../i18n/config";
import { BASE_URL, OG_IMAGE, organizationJsonLd } from "../lib/seo";

interface Props {
  lang: Locale;
  /** ページの論理パス（"/" や "/about"）。ロケール接頭辞は含めない。 */
  path: string;
  title: string;
  description: string;
  ogImage?: string;
  jsonLd?: Record<string, unknown>;
  /** 管理画面など検索対象外ページは true */
  noindex?: boolean;
}

const {
  lang,
  path,
  title,
  description,
  ogImage = OG_IMAGE,
  jsonLd,
  noindex = false,
} = Astro.props;

// canonical は自ロケールの絶対URL
const canonical = `${BASE_URL}${localizedPath(lang, path)}`;
// hreflang は全ロケール＋x-default(=en)
const alternates = LOCALES.map((loc) => ({
  hreflang: HREFLANG[loc],
  href: `${BASE_URL}${localizedPath(loc, path)}`,
}));
const xDefault = `${BASE_URL}${localizedPath(DEFAULT_LOCALE, path)}`;
// html lang 属性（zh は繁体字）
const htmlLang = HREFLANG[lang];
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />

    {
      noindex ? (
        <meta name="robots" content="noindex,nofollow" />
      ) : (
        <link rel="canonical" href={canonical} />
      )
    }

    {
      !noindex &&
        alternates.map((alt) => (
          <link rel="alternate" hreflang={alt.hreflang} href={alt.href} />
        ))
    }
    {!noindex && <link rel="alternate" hreflang="x-default" href={xDefault} />}

    <!-- OGP -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />

    {
      jsonLd && (
        <script
          is:inline
          type="application/ld+json"
          set:html={JSON.stringify(jsonLd)}
        />
      )
    }

    <!-- Organization（運営会社）JSON-LD — 全ページ共通・sameAsでエンティティ接続 -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify(organizationJsonLd())} />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <!-- B11: フォント preload（見出し/本文の FOUT 抑制） -->
    <link rel="preload" href="/fonts/national-2-medium.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/national-2-regular.woff2" as="font" type="font/woff2" crossorigin />

    <!-- GA4 — 既存プロパティ www.yah.homes（G-VJ5DDRML79）を流用しデータ継続 -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-VJ5DDRML79"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());
      gtag("config", "G-VJ5DDRML79");

      // GA4 イベント計測（クリック委譲・リンク先ドメインで自動判定）
      document.addEventListener("click", function (e) {
        var a = e.target && e.target.closest ? e.target.closest("a") : null;
        if (!a) return;
        var href = a.getAttribute("href") || "";
        var path = location.pathname;
        // 物件判定: URLのroom ID or 現在ページのパス
        var property =
          href.indexOf("1427842426961787667") > -1 || path.indexOf("kiyokawa") > -1
            ? "kiyokawa"
            : href.indexOf("1497546315476018480") > -1 || path.indexOf("takasago") > -1
              ? "takasago"
              : "general";
        if (href.indexOf("airbnb") > -1) {
          gtag("event", "click_airbnb", { property: property, page_path: path });
        } else if (href.indexOf("booking.com") > -1) {
          gtag("event", "click_booking_com", { property: property, page_path: path });
        } else if (href === "#booking") {
          gtag("event", "click_booking_calendar", { property: property, page_path: path });
        } else if (href.indexOf("instagram.com") > -1) {
          gtag("event", "click_instagram", { page_path: path });
        } else if (href.indexOf("prtimes.jp") > -1) {
          gtag("event", "click_press", { page_path: path });
        }
      });
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
