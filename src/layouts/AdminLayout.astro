---
// 管理画面の枠（Phase 1）。noindex・認証未実装・実データなし（プレースホルダのみ）。
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  active: string;
}
const { title, active } = Astro.props;

const items = [
  { key: "menu", href: "/admin/", label: "Menu" },
  { key: "dashboard", href: "/admin/dashboard/", label: "Dashboard" },
  { key: "inbox", href: "/admin/inbox/", label: "Inbox" },
  { key: "instagram", href: "/admin/instagram/", label: "Instagram" },
  { key: "analytics", href: "/admin/analytics/", label: "Analytics" },
  { key: "docs", href: "/admin/docs/", label: "Docs" },
];
---

<BaseLayout
  lang="en"
  path="/admin"
  title={`${title} | yah.homes Admin`}
  description="yah.homes admin (internal)."
  noindex={true}
>
  <div class="admin">
    <aside class="admin-nav">
      <div class="admin-brand">yah.homes<span>admin</span></div>
      <nav>
        {items.map((it) => (
          <a href={it.href} aria-current={it.key === active ? "page" : undefined}>{it.label}</a>
        ))}
      </nav>
    </aside>
    <main class="admin-main">
      <header class="admin-head"><h1>{title}</h1></header>
      <div class="admin-body">
        <slot />
        <p class="placeholder-note">
          この画面は枠のみです（Phase 1）。認証・データ連携は今後のフェーズで実装します。
        </p>
      </div>
    </main>
  </div>
</BaseLayout>

<style>
  .admin { display: grid; grid-template-columns: 220px 1fr; min-height: 100vh; }
  .admin-nav { background: #111; color: #fff; padding: 1.5rem 1rem; }
  .admin-brand { font-weight: 500; font-size: 1.1rem; margin-bottom: 2rem; }
  .admin-brand span { display: block; font-size: 0.65rem; letter-spacing: 0.2em; text-transform: uppercase; color: #888; }
  .admin-nav nav { display: flex; flex-direction: column; gap: 0.25rem; }
  .admin-nav a { color: #ccc; text-decoration: none; padding: 0.6rem 0.75rem; border-radius: 6px; font-size: 0.9rem; }
  .admin-nav a:hover { background: #1e1e1e; color: #fff; }
  .admin-nav a[aria-current="page"] { background: #262626; color: #fff; }
  .admin-main { padding: 2rem 2.5rem; }
  .admin-head h1 { font-size: 1.5rem; font-weight: 500; margin-bottom: 1.5rem; }
  .placeholder-note { margin-top: 2rem; padding: 1rem 1.25rem; background: var(--secondary); border: 1px dashed var(--border); font-size: 0.85rem; color: var(--muted-foreground); }
  @media (max-width: 640px) { .admin { grid-template-columns: 1fr; } .admin-nav { display: none; } }
</style>
