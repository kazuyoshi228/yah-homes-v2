---
// 公開ページ用レイアウト = BaseLayout(head) + Navbar + slot + Footer
// scroll reveal（.reveal / .reveal-fade → .visible）のオブザーバも全ページ共通で有効化
import BaseLayout from "./BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import type { Locale } from "../i18n/config";

interface Props {
  lang: Locale;
  path: string;
  title: string;
  description: string;
  ogImage?: string;
  ogType?: string;
  jsonLd?: Record<string, unknown>;
  noindex?: boolean;
  /** 翻訳が存在する言語のみ hreflang を出す（ガイド記事用） */
  availableLocales?: Locale[];
  /** ヒーローのないページ用: ナビを白背景固定に */
  solidNav?: boolean;
}
const { lang, path, title, description, ogImage, ogType, jsonLd, noindex, availableLocales, solidNav } = Astro.props;
---

<BaseLayout
  lang={lang}
  path={path}
  title={title}
  description={description}
  ogImage={ogImage}
  ogType={ogType}
  jsonLd={jsonLd}
  noindex={noindex}
  availableLocales={availableLocales}
>
  <Navbar lang={lang} path={path} solid={solidNav} />
  <slot />
  <Footer lang={lang} />

  <script>
    // scroll reveal — 旧サイトの IntersectionObserver 動作を全ページ共通化
    const observer = new IntersectionObserver(
      (entries) => entries.forEach((e) => e.isIntersecting && e.target.classList.add("visible")),
      { threshold: 0.08 }
    );
    document.querySelectorAll(".reveal, .reveal-fade").forEach((el) => observer.observe(el));
  </script>
</BaseLayout>
