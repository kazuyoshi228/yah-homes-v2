---
/* yah.homes ContactSection — 旧 ContactSection.tsx の忠実移植
   B8: Cloud Function `contact` へ POST → Firestore(contacts) に保存
   （ルールは全deny・Admin SDK経由のみ。ハニーポット website フィールド付き） */
import { translations } from "../../i18n/translations";
import type { Locale } from "../../i18n/config";

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
const c = translations[lang].contact;

const CONTACT_ENDPOINT = "https://asia-northeast1-yah-homes.cloudfunctions.net/contact";
---

<section id="contact" style="background:#f7f7f7;padding:5rem 1.5rem 6rem;">
  <div style="max-width:560px;margin:0 auto;">
    <p class="c-label">{c.sectionLabel}</p>
    <h2 class="c-heading">{c.heading}</h2>
    <p class="c-sub">{c.subheading}</p>

    <form
      id="contact-form"
      novalidate
      data-endpoint={CONTACT_ENDPOINT}
      data-lang={lang}
      data-success={c.successMsg}
      data-error={c.errorMsg}
    >
      <!-- honeypot（不可視・botが埋める） -->
      <input type="text" name="website" tabindex="-1" autocomplete="off" aria-hidden="true" style="position:absolute;left:-9999px;height:0;width:0;opacity:0;" />

      <div style="margin-bottom:1.25rem;">
        <label class="f-label" for="cf-name">Full Name <span style="color:#cc0000;">*</span></label>
        <input class="f-input" id="cf-name" type="text" name="name" placeholder={c.namePlaceholder} autocomplete="name" required />
      </div>

      <div style="margin-bottom:1.25rem;">
        <label class="f-label" for="cf-email">Email <span style="color:#cc0000;">*</span></label>
        <input class="f-input" id="cf-email" type="email" name="email" placeholder={c.emailPlaceholder} autocomplete="email" required />
      </div>

      <div style="margin-bottom:1.25rem;">
        <label class="f-label" for="cf-message">Message</label>
        <textarea class="f-input" id="cf-message" name="message" rows="5" placeholder={c.messagePlaceholder} style="resize:vertical;"></textarea>
      </div>

      <div style="margin-bottom:1.5rem;">
        <label style="display:flex;align-items:flex-start;gap:0.5rem;cursor:pointer;">
          <input type="checkbox" name="privacy" style="margin-top:2px;cursor:pointer;" />
          <span style="font-size:0.9375rem;font-weight:400;color:#444444;">
            I agree to the <span style="text-decoration:underline;">Privacy Policy</span>.
          </span>
        </label>
      </div>

      <button type="submit" class="f-submit">{c.submitBtn}</button>
    </form>
  </div>
</section>

<style>
  .c-label {
    font-size: 0.7rem;
    font-weight: 500;
    color: #aaaaaa;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }
  .c-heading {
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    font-weight: 500;
    color: #111111;
    margin-bottom: 0.5rem;
    letter-spacing: -0.01em;
  }
  .c-sub {
    font-size: 0.9375rem;
    font-weight: 300;
    color: #666666;
    margin-bottom: 2rem;
  }
  .f-label {
    display: block;
    font-size: 0.9375rem;
    font-weight: 500;
    color: #111111;
    margin-bottom: 0.375rem;
    letter-spacing: -0.01em;
  }
  .f-input {
    width: 100%;
    padding: 0.625rem 0.75rem;
    border: 1px solid #e8e8e8;
    background: #ffffff;
    font: inherit;
    font-size: 0.9375rem;
    color: #111111;
    outline: none;
    transition: border-color 0.2s ease;
    border-radius: 4px;
  }
  .f-input:focus {
    border-color: #111111;
  }
  .f-submit {
    width: 100%;
    padding: 0.75rem;
    background: #111111;
    color: #ffffff;
    font-size: 1.125rem;
    font-weight: 500;
    letter-spacing: -0.01em;
    border: none;
    cursor: pointer;
    transition: background 0.2s ease, transform 0.15s ease;
  }
  .f-submit:hover {
    background: #333333;
  }
  .f-submit:active {
    transform: scale(0.98);
  }
</style>

<script>
  // B8: Cloud Function へ送信 → 成功で successMsg 表示 / 失敗で errorMsg
  const form = document.getElementById("contact-form") as HTMLFormElement | null;
  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const endpoint = form.dataset.endpoint!;
    const btn = form.querySelector<HTMLButtonElement>(".f-submit");
    const name = (form.querySelector<HTMLInputElement>('[name="name"]')?.value ?? "").trim();
    const email = (form.querySelector<HTMLInputElement>('[name="email"]')?.value ?? "").trim();
    const message = (form.querySelector<HTMLTextAreaElement>('[name="message"]')?.value ?? "").trim();
    const website = form.querySelector<HTMLInputElement>('[name="website"]')?.value ?? "";
    const privacy = form.querySelector<HTMLInputElement>('[name="privacy"]')?.checked;

    // 簡易バリデーション（旧実装と同基準）
    if (!name || !/\S+@\S+\.\S+/.test(email) || !message || !privacy) {
      form.reportValidity();
      if (!privacy) alert("Please agree to the Privacy Policy.");
      return;
    }

    if (btn) {
      btn.disabled = true;
      btn.dataset.label = btn.textContent ?? "";
      btn.textContent = "Sending...";
    }
    try {
      const res = await fetch(endpoint, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ name, email, message, website, lang: form.dataset.lang }),
      });
      if (!res.ok) throw new Error("bad_status");
      // 成功: フォームを successMsg に置き換え（旧実装と同じ挙動）
      const done = document.createElement("div");
      done.style.cssText = "text-align:center;padding:3rem 0;";
      done.innerHTML = `<p style="font-size:1.5rem;font-weight:500;color:#111111;">${form.dataset.success}</p>`;
      form.replaceWith(done);
    } catch {
      alert(form.dataset.error || "Failed to send. Please try again later.");
      if (btn) {
        btn.disabled = false;
        btn.textContent = btn.dataset.label || "Send";
      }
    }
  });
</script>
