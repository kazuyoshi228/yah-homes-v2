---
/* yah.homes ContactSection — 旧 ContactSection.tsx の忠実移植（UI）
   Phase 1: 送信バックエンド未接続のためフォームは表示のみ（submitは無効化） */
import { translations } from "../../i18n/translations";
import type { Locale } from "../../i18n/config";

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
const c = translations[lang].contact;
---

<section id="contact" style="background:#f7f7f7;padding:5rem 1.5rem 6rem;">
  <div style="max-width:560px;margin:0 auto;">
    <p class="c-label">{c.sectionLabel}</p>
    <h2 class="c-heading">{c.heading}</h2>
    <p class="c-sub">{c.subheading}</p>

    <form id="contact-form" novalidate>
      <div style="margin-bottom:1.25rem;">
        <label class="f-label" for="cf-name">Full Name <span style="color:#cc0000;">*</span></label>
        <input class="f-input" id="cf-name" type="text" name="name" placeholder={c.namePlaceholder} autocomplete="name" />
      </div>

      <div style="margin-bottom:1.25rem;">
        <label class="f-label" for="cf-email">Email <span style="color:#cc0000;">*</span></label>
        <input class="f-input" id="cf-email" type="email" name="email" placeholder={c.emailPlaceholder} autocomplete="email" />
      </div>

      <div style="margin-bottom:1.25rem;">
        <label class="f-label" for="cf-message">Message</label>
        <textarea class="f-input" id="cf-message" name="message" rows="5" placeholder={c.messagePlaceholder} style="resize:vertical;"></textarea>
      </div>

      <div style="margin-bottom:1.5rem;">
        <label style="display:flex;align-items:flex-start;gap:0.5rem;cursor:pointer;">
          <input type="checkbox" name="privacy" style="margin-top:2px;cursor:pointer;" />
          <span style="font-size:0.9375rem;font-weight:400;color:#444444;">
            I agree to the <span style="text-decoration:underline;">Privacy Policy</span>.
          </span>
        </label>
      </div>

      <button type="submit" class="f-submit">{c.submitBtn}</button>
    </form>
  </div>
</section>

<style>
  .c-label {
    font-size: 0.7rem;
    font-weight: 500;
    color: #aaaaaa;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }
  .c-heading {
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    font-weight: 500;
    color: #111111;
    margin-bottom: 0.5rem;
    letter-spacing: -0.01em;
  }
  .c-sub {
    font-size: 0.9375rem;
    font-weight: 300;
    color: #666666;
    margin-bottom: 2rem;
  }
  .f-label {
    display: block;
    font-size: 0.9375rem;
    font-weight: 500;
    color: #111111;
    margin-bottom: 0.375rem;
    letter-spacing: -0.01em;
  }
  .f-input {
    width: 100%;
    padding: 0.625rem 0.75rem;
    border: 1px solid #d0d0d0;
    background: #ffffff;
    font: inherit;
    font-size: 0.9375rem;
    color: #111111;
    outline: none;
    transition: border-color 0.2s ease;
    border-radius: 2px;
  }
  .f-input:focus {
    border-color: #111111;
  }
  .f-submit {
    width: 100%;
    padding: 0.75rem;
    background: #111111;
    color: #ffffff;
    font-size: 1.125rem;
    font-weight: 500;
    letter-spacing: -0.01em;
    border: none;
    cursor: pointer;
    transition: background 0.2s ease, transform 0.15s ease;
  }
  .f-submit:hover {
    background: #333333;
  }
  .f-submit:active {
    transform: scale(0.98);
  }
</style>

<script>
  // Phase 1: 送信バックエンド未接続 — 送信は次フェーズ（Cloud Functions）で有効化
  document.getElementById("contact-form")?.addEventListener("submit", (e) => {
    e.preventDefault();
  });
</script>
