---
/* 両棟Airbnb予約CTA（共通部品）— HERO/レビュー直後/比較表直後/末尾で再利用。
   URL・評価・件数・取得日は src/data/properties.ts（RATING_AS_OF / PROPERTIES）を単一ソースに参照。
   計測: BaseLayout のクリック委譲が room ID で property を自動判定し click_airbnb を送信。
   data-cta-location で配置別に分離計測する。 */
import { PROPERTIES, RATING_AS_OF } from "../../data/properties";
import type { Locale } from "../../i18n/config";

interface Props {
  lang: Locale;
  /** 計測の配置ラベル（GA4 cta_location に載る） */
  ctaLocation: "hero" | "after_review" | "after_compare" | "footer_cta";
  /** ★評価＋取得日の補助行を出すか（HERO用） */
  showRating?: boolean;
  /** 中央寄せ（レビュー/比較/末尾）か左寄せ（HERO）か */
  align?: "center" | "left";
}
const { lang, ctaLocation, showRating = false, align = "center" } = Astro.props;

const k = PROPERTIES.kiyokawa;
const t = PROPERTIES.takasago;

const ratingLabel =
  lang === "ja"
    ? `★${k.rating} 清川（${k.reviewCount}件）・★${t.rating} 高砂（${t.reviewCount}件）｜${RATING_AS_OF} 時点`
    : lang === "ko"
      ? `★${k.rating} Kiyokawa (${k.reviewCount}) · ★${t.rating} Takasago (${t.reviewCount}) | ${RATING_AS_OF} 기준`
      : lang === "zh"
        ? `★${k.rating} 清川（${k.reviewCount}則）・★${t.rating} 高砂（${t.reviewCount}則）｜${RATING_AS_OF} 時點`
        : lang === "th"
          ? `★${k.rating} Kiyokawa (${k.reviewCount}) · ★${t.rating} Takasago (${t.reviewCount}) | ${RATING_AS_OF}`
          : `★${k.rating} Kiyokawa (${k.reviewCount}) · ★${t.rating} Takasago (${t.reviewCount}) | as of ${RATING_AS_OF}`;

const AirbnbIcon = `<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C8.5 2 5.5 5.5 5.5 9.5c0 2.5 1.2 4.8 3.2 6.5L12 22l3.3-6c2-1.7 3.2-4 3.2-6.5C18.5 5.5 15.5 2 12 2zm0 10a2.5 2.5 0 1 1 0-5 2.5 2.5 0 0 1 0 5z"></path></svg>`;
---

<div class:list={["ibc", `ibc-${align}`]}>
  <div class="ibc-pills">
    <a
      href={k.airbnbUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="airbnb-pill"
      data-cta-location={ctaLocation}
    >
      <Fragment set:html={AirbnbIcon} />
      Airbnb — Kiyokawa
    </a>
    <a
      href={t.airbnbUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="airbnb-pill"
      data-cta-location={ctaLocation}
    >
      <Fragment set:html={AirbnbIcon} />
      Airbnb — Takasago
    </a>
  </div>
  {showRating && <p class="ibc-rating">{ratingLabel}</p>}
</div>

<style>
  .ibc-center {
    text-align: center;
  }
  .ibc-pills {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .ibc-center .ibc-pills {
    justify-content: center;
  }
  .ibc-left .ibc-pills {
    justify-content: flex-start;
  }
  .airbnb-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    background: #ff5a5f;
    color: #ffffff;
    border-radius: 999px;
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    text-decoration: none;
    box-shadow: 0 2px 12px rgba(255, 90, 95, 0.35);
    transition: opacity 0.18s ease, transform 0.15s ease;
  }
  .airbnb-pill:hover {
    opacity: 0.85;
    transform: translateY(-2px);
  }
  .airbnb-pill:active {
    transform: scale(0.97);
  }
  .ibc-rating {
    margin: 0.9rem 0 0;
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.85);
    letter-spacing: 0.01em;
  }
  /* 明るい背景（レビュー/比較の直後）ではrating行を暗色に上書き */
  .ibc-on-light .ibc-rating {
    color: #888888;
  }
  @media (max-width: 420px) {
    .ibc-pills {
      flex-direction: column;
    }
    .airbnb-pill {
      justify-content: center;
    }
  }
</style>
