const STORY_IMG = "/manus-storage/story-hero_803d730b.webp";
---

<section id="about" style="background:#f7f7f7;padding:5rem 0;">
  <div style="max-width:900px;margin:0 auto;padding:0 1.5rem;">
    <div class="reveal-fade img-zoom" style="overflow:hidden;">
      <img
        src={STORY_IMG}
        alt="yah.homes interior"
        loading="lazy"
        decoding="async"
        width="900"
        height="600"
        style="width:100%;display:block;"
      />
    </div>
  </div>
</section>
