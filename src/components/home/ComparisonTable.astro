---
/* yah.homes ComparisonTable — 旧 ComparisonTable.tsx の忠実移植 */
import { translations } from "../../i18n/translations";
import type { Locale } from "../../i18n/config";

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
const t = translations[lang];
const ct = t.comparisonTable;

// 人数単位（旧実装のロジックを言語で直接分岐）
const peopleUnit = lang === "ko" ? "명" : lang === "zh" ? "人" : lang === "th" ? "คน" : "People";

type Row =
  | { type: "header"; label: string }
  | { type: "row"; label: string; kiyokawa: string; takasago: string };

const ROWS: Row[] = [
  { type: "header", label: ct.headers.capacity },
  { type: "row", label: ct.rows.maxCapacity, kiyokawa: `7 ${peopleUnit}`, takasago: `6 ${peopleUnit}` },

  { type: "header", label: ct.headers.rooms },
  { type: "row", label: ct.rows.bedrooms, kiyokawa: "3", takasago: "3" },
  { type: "row", label: ct.rows.doubleBed, kiyokawa: "3", takasago: "1" },
  { type: "row", label: ct.rows.singleBed, kiyokawa: "1", takasago: "4" },
  { type: "row", label: ct.rows.bathroom, kiyokawa: "1", takasago: "1" },
  { type: "row", label: ct.rows.showerBooth, kiyokawa: "—", takasago: "1" },
  { type: "row", label: ct.rows.toilet, kiyokawa: "2", takasago: "2" },

  { type: "header", label: ct.headers.facilities },
  { type: "row", label: ct.rows.privateParking, kiyokawa: ct.values.available, takasago: ct.values.available },
  { type: "row", label: ct.rows.theaterRoom, kiyokawa: "—", takasago: ct.values.available },

  { type: "header", label: ct.headers.access },
  { type: "row", label: ct.rows.fromAirport, kiyokawa: ct.values.car18min, takasago: ct.values.car20min },
  { type: "row", label: ct.rows.fromStation, kiyokawa: ct.values.walk15min, takasago: ct.values.walk8min },
  { type: "row", label: ct.rows.nearestStation, kiyokawa: ct.values.watanabeDori, takasago: ct.values.watanabeDori },
  { type: "row", label: ct.rows.toTenjin, kiyokawa: ct.values.walk20min, takasago: ct.values.walk15min },
  { type: "row", label: ct.rows.toHakata, kiyokawa: ct.values.walk25min, takasago: ct.values.walk25min },
];

function cellClass(v: string): string {
  if (v === "—") return "val dash";
  if (v === ct.values.available) return "val avail";
  return "val";
}
---

<div style="max-width:900px;margin:0 auto;padding:0 1.5rem 5rem;">
  <h2 class="cmp-title">{ct.title}</h2>
  <div style="overflow-x:auto;-webkit-overflow-scrolling:touch;">
    <table class="cmp-table">
      <thead>
        <tr>
          <th class="th-label"></th>
          <th class="th-prop">{t.properties.kiyokawa.name}</th>
          <th class="th-prop">{t.properties.takasago.name}</th>
        </tr>
      </thead>
      <tbody>
        {
          ROWS.map((row) =>
            row.type === "header" ? (
              <tr>
                <td colspan="3" class="cat-head">{row.label}</td>
              </tr>
            ) : (
              <tr
                class="data-row"
                data-sub={row.label.startsWith("·") || row.label.startsWith("·") ? "true" : undefined}
              >
                <td class="row-label">{row.label}</td>
                <td class={cellClass(row.kiyokawa)}>{row.kiyokawa}</td>
                <td class={cellClass(row.takasago)}>{row.takasago}</td>
              </tr>
            )
          )
        }
      </tbody>
    </table>
  </div>
</div>

<style>
  .cmp-title {
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    font-weight: 500;
    color: #111111;
    margin-bottom: 2rem;
    letter-spacing: -0.01em;
    line-height: 1.4;
  }
  .cmp-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
    color: #111111;
  }
  .th-label {
    width: 40%;
    padding: 0.75rem 0;
    text-align: left;
    font-weight: 300;
    color: #888888;
    border-bottom: 1px solid #111111;
    letter-spacing: 0.04em;
    font-size: 0.75rem;
    text-transform: uppercase;
  }
  .th-prop {
    width: 30%;
    padding: 0.75rem 1rem;
    text-align: center;
    font-weight: 500;
    color: #111111;
    border-bottom: 1px solid #111111;
    letter-spacing: -0.01em;
    font-size: 1rem;
  }
  .cat-head {
    padding: 1.25rem 0 0.4rem;
    font-weight: 500;
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #888888;
  }
  .data-row {
    border-bottom: 1px solid #f0f0f0;
    transition: background 0.15s;
  }
  .data-row:hover {
    background: #fafafa;
  }
  .row-label {
    padding: 0.65rem 0;
    font-weight: 300;
    color: #333333;
  }
  .data-row[data-sub="true"] .row-label {
    color: #888888;
    padding-left: 1rem;
    font-size: 0.8rem;
  }
  .val {
    padding: 0.65rem 1rem;
    text-align: center;
    font-weight: 300;
    color: #333333;
  }
  .val.dash {
    color: #cccccc;
  }
  .val.avail {
    font-weight: 500;
    color: #111111;
  }
</style>
