---
// サイト共通ヘッダー。言語切替・モバイルメニューは native <details> でJS不要。
import { LOCALES, localizedPath, type Locale } from "../i18n/config";
import { translations } from "../i18n/translations";

interface Props {
  lang: Locale;
  /** 現在ページの論理パス（言語切替のリンク先算出に使用） */
  path: string;
}
const { lang, path } = Astro.props;
const t = translations[lang].nav;

const navItems = [
  { key: "home", href: localizedPath(lang, "/"), label: t.home },
  { key: "properties", href: localizedPath(lang, "/booking"), label: t.properties },
  { key: "locals", href: localizedPath(lang, "/locals"), label: t.locals },
  { key: "about", href: localizedPath(lang, "/about"), label: t.about },
];
---

<header class="site-header">
  <div class="container header-inner">
    <a href={localizedPath(lang, "/")} class="brand" aria-label="yah.homes home">yah.homes</a>

    <nav class="nav-desktop" aria-label="Primary">
      {navItems.map((it) => <a href={it.href} class="link-underline">{it.label}</a>)}
    </nav>

    <div class="header-right">
      <!-- 言語切替（JS不要） -->
      <details class="lang">
        <summary aria-label={t.language}>{t.langNames[lang]}</summary>
        <ul class="lang-menu">
          {
            LOCALES.map((loc) => (
              <li>
                <a href={localizedPath(loc, path)} hreflang={loc} aria-current={loc === lang ? "true" : undefined}>
                  {t.langNames[loc]}
                </a>
              </li>
            ))
          }
        </ul>
      </details>

      <!-- モバイルメニュー（JS不要） -->
      <details class="mobile-menu">
        <summary aria-label={t.menuOpen}>
          <span class="burger" aria-hidden="true"></span>
        </summary>
        <nav class="mobile-nav" aria-label="Mobile">
          {navItems.map((it) => <a href={it.href}>{it.label}</a>)}
        </nav>
      </details>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: saturate(180%) blur(8px);
    border-bottom: 1px solid var(--border);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 60px;
  }
  .brand {
    font-weight: 500;
    font-size: 1.15rem;
    letter-spacing: 0.02em;
    color: var(--foreground);
    text-decoration: none;
  }
  .nav-desktop {
    display: none;
    gap: 2rem;
    font-size: 0.8rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .nav-desktop a {
    color: var(--foreground);
    text-decoration: none;
  }
  .header-right {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  details.lang {
    position: relative;
    font-size: 0.8rem;
  }
  details.lang summary {
    list-style: none;
    cursor: pointer;
    padding: 0.35rem 0.6rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    letter-spacing: 0.04em;
  }
  details.lang summary::-webkit-details-marker {
    display: none;
  }
  .lang-menu {
    position: absolute;
    right: 0;
    top: calc(100% + 6px);
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 8px;
    min-width: 130px;
    padding: 0.25rem;
    list-style: none;
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.08);
  }
  .lang-menu a {
    display: block;
    padding: 0.5rem 0.75rem;
    color: var(--foreground);
    text-decoration: none;
    border-radius: 6px;
    font-size: 0.85rem;
  }
  .lang-menu a[aria-current="true"] {
    font-weight: 500;
    background: var(--secondary);
  }
  .lang-menu a:hover {
    background: var(--secondary);
  }
  details.mobile-menu summary {
    list-style: none;
    cursor: pointer;
    padding: 0.4rem;
  }
  details.mobile-menu summary::-webkit-details-marker {
    display: none;
  }
  .burger,
  .burger::before,
  .burger::after {
    display: block;
    width: 22px;
    height: 1.5px;
    background: var(--foreground);
    content: "";
    position: relative;
  }
  .burger::before {
    top: -6px;
    position: absolute;
  }
  .burger::after {
    top: 6px;
    position: absolute;
  }
  .mobile-nav {
    position: absolute;
    left: 0;
    right: 0;
    top: 60px;
    background: #fff;
    border-bottom: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    padding: 0.5rem 1.5rem 1.25rem;
  }
  .mobile-nav a {
    padding: 0.85rem 0;
    color: var(--foreground);
    text-decoration: none;
    border-bottom: 1px solid var(--border);
    font-size: 0.95rem;
  }
  @media (min-width: 768px) {
    .nav-desktop {
      display: flex;
    }
    details.mobile-menu {
      display: none;
    }
  }
</style>
