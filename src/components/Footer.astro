---
import { localizedPath, type Locale } from "../i18n/config";
import { translations } from "../i18n/translations";

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
const t = translations[lang].nav;
const year = 2026;

const links = [
  { href: localizedPath(lang, "/"), label: t.home },
  { href: localizedPath(lang, "/booking"), label: t.properties },
  { href: localizedPath(lang, "/locals"), label: t.locals },
  { href: localizedPath(lang, "/about"), label: t.about },
];
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-brand">yah.homes</div>
    <nav class="footer-nav" aria-label="Footer">
      {links.map((l) => <a href={l.href}>{l.label}</a>)}
    </nav>
    <p class="copy">© {year} yah.homes — Whole-House Stays in Fukuoka, Japan</p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--border);
    margin-top: 5rem;
    padding: 3rem 0;
  }
  .footer-inner {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: center;
    text-align: center;
  }
  .footer-brand {
    font-weight: 500;
    font-size: 1.1rem;
  }
  .footer-nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1.5rem;
    font-size: 0.8rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  .footer-nav a {
    color: var(--muted-foreground);
    text-decoration: none;
  }
  .footer-nav a:hover {
    color: var(--foreground);
  }
  .copy {
    font-size: 0.75rem;
    color: var(--muted-foreground);
  }
</style>
