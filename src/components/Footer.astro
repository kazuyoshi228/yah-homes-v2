---
/* yah.homes Footer — 旧 Footer.tsx の忠実移植（ロゴSVG＋rights のみ） */
import LogoYah from "./LogoYah.astro";
import { translations } from "../i18n/translations";
import { localizedPath, type Locale } from "../i18n/config";

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
const t = translations[lang];
// GEO: 更新日の可視化（鮮度シグナル・ビルド日）
const updated = new Date().toISOString().slice(0, 10);

const aboutHref = localizedPath(lang, "/about");
const legalHref = localizedPath(lang, "/legal/tokushoho");
const LEGAL_LABEL: Record<Locale, string> = {
  ja: "特定商取引法に基づく表記", en: "Legal Notice", ko: "특정상거래법 표기", zh: "特定商業交易法標示", th: "ประกาศทางกฎหมาย",
};
const ABOUT_LABEL: Record<Locale, string> = {
  ja: "会社概要", en: "Company", ko: "회사 정보", zh: "公司資訊", th: "ข้อมูลบริษัท",
};
---

<footer style="background:#ffffff;border-top:1px solid #e8e8e8;padding:2rem 1.5rem;">
  <div
    style="max-width:900px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem;"
  >
    <div style="display:flex;align-items:center;gap:1.25rem;">
      <LogoYah height="32px" fill="#231815" />
      <!-- 公式Instagram（可視リンク＝エンティティ相互接続・モノクロでブランド準拠） -->
      <a
        href="https://www.instagram.com/yah.homes/"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="yah.homes Instagram"
        style="display:inline-flex;align-items:center;gap:0.35rem;color:#888888;text-decoration:none;font-size:0.75rem;letter-spacing:0.04em;"
        onmouseover="this.style.color='#111111'"
        onmouseout="this.style.color='#888888'"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
          <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
          <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
        </svg>
        Instagram
      </a>
    </div>
    <div style="display:flex;flex-direction:column;align-items:flex-end;gap:0.5rem;">
      <nav style="display:flex;gap:1rem;flex-wrap:wrap;justify-content:flex-end;">
        <a href={aboutHref} style="font-size:0.75rem;color:#888888;text-decoration:none;" onmouseover="this.style.color='#111111'" onmouseout="this.style.color='#888888'">{ABOUT_LABEL[lang]}</a>
        <a href={legalHref} style="font-size:0.75rem;color:#888888;text-decoration:none;" onmouseover="this.style.color='#111111'" onmouseout="this.style.color='#888888'">{LEGAL_LABEL[lang]}</a>
      </nav>
      <p style="font-size:0.75rem;font-weight:400;color:#aaaaaa;margin:0;">
        {t.footer.rights}
        <span style="margin-left:0.75rem;color:#cccccc;">Updated {updated}</span>
      </p>
    </div>
  </div>
</footer>
